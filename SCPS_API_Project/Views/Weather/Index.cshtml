@model SCPS_API_Project.Models.WeatherIndexViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Weather";

    var tempData = Model.Historical
        .Select(h => new { x = h.TimeStamp.ToLocalTime().ToString("MM-dd HH:mm"), y = h.Temperature })
        .ToList();

    var windData = Model.Historical
        .Select(h => new { x = h.TimeStamp.ToLocalTime().ToString("MM-dd HH:mm"), y = h.WindSpeed })
        .ToList();

    var tempJson = JsonSerializer.Serialize(tempData);
    var windJson = JsonSerializer.Serialize(windData);

    var tempMin = Model.Historical.Any() ? Math.Floor(Model.Historical.Min(h => h.Temperature)) - 1 : 0;
    var tempMax = Model.Historical.Any() ? Math.Ceiling(Model.Historical.Max(h => h.Temperature)) + 1 : 0;
    var windMin = Model.Historical.Any() ? Math.Floor(Model.Historical.Min(h => h.WindSpeed)) - 1 : 0;
    var windMax = Model.Historical.Any() ? Math.Ceiling(Model.Historical.Max(h => h.WindSpeed)) + 1 : 0;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Weather — Stigs Bjergby</h1>
    <form asp-action="FetchNow" method="post">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-success">Fetch New Snapshot</button>
    </form>
</div>

@if (!Model.Historical.Any())
{
    <div class="alert alert-info">
        No data yet. Click <strong>Fetch New Snapshot</strong> to get the first reading.
    </div>
}
else
{
    <div style="position:relative; height:380px;" class="mb-5">
        <canvas id="tempChart"></canvas>
    </div>

    <h2 class="mb-2">Recorded Snapshots</h2>
    <div class="table-responsive">
        <table class="table table-sm table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Time</th>
                    <th>Temp (°C)</th>
                    <th>Wind (km/h)</th>
                    <th>Direction</th>
                    <th>Sky</th>
                    <th>Condition</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Historical.Reverse())
                {
                    <tr>
                        <td>@item.TimeStamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td><strong>@item.Temperature °C</strong></td>
                        <td>@item.WindSpeed</td>
                        <td>@item.WindDirection</td>
                        <td>@item.SkyCondition</td>
                        <td>@item.WxPhrase</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
    @if (Model.Historical.Any())
    {
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
            new Chart(document.getElementById('tempChart'), {
                type: 'line',
                data: {
                    datasets: [
                        {
                            label: 'Temperature (°C)',
                            data: @Html.Raw(tempJson),
                            borderColor: '#0d6efd',
                            backgroundColor: 'rgba(13,110,253,0.08)',
                            tension: 0.3,
                            pointRadius: 4,
                            fill: false,
                            yAxisID: 'yTemp'
                        },
                        {
                            label: 'Wind (km/h)',
                            data: @Html.Raw(windJson),
                            borderColor: '#198754',
                            backgroundColor: 'rgba(25,135,84,0.08)',
                            tension: 0.3,
                            pointRadius: 4,
                            fill: false,
                            yAxisID: 'yWind'
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    parsing: { xAxisKey: 'x', yAxisKey: 'y' },
                    scales: {
                        x: {
                            type: 'category',
                            title: { display: true, text: 'Time' },
                            ticks: { maxTicksLimit: 24, maxRotation: 45 }
                        },
                        yTemp: {
                            type: 'linear',
                            position: 'left',
                            min: @tempMin,
                            max: @tempMax,
                            title: { display: true, text: 'Temperature (°C)' }
                        },
                        yWind: {
                            type: 'linear',
                            position: 'right',
                            min: @windMin,
                            max: @windMax,
                            title: { display: true, text: 'Wind (km/h)' },
                            grid: { drawOnChartArea: false }
                        }
                    },
                    plugins: {
                        legend: { position: 'top' },
                        tooltip: { mode: 'index', intersect: false }
                    }
                }
            });
        </script>
    }
}
