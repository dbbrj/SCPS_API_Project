@model SCPS_API_Project.Models.WeatherIndexViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Weather";

    var historicalAsc = Model.Historical.OrderBy(h => h.TimeStamp).ToList();

    var histLabels = historicalAsc.Select(h => h.TimeStamp.ToLocalTime().ToString("MM-dd HH:mm")).ToList();
    var histTemps  = historicalAsc.Select(h => h.Temperature).ToList();

    var foreLabels = Model.Forecast.Select(f => f.ValidTime.ToLocalTime().ToString("MM-dd HH:mm")).ToList();
    var foreTemps  = Model.Forecast.Select(f => (object?)f.Temperature).ToList();

    var allLabels  = histLabels.Concat(foreLabels).Distinct().Order().ToList();

    var histJson = JsonSerializer.Serialize(histLabels.Zip(histTemps).Select(x => new { x = x.First, y = x.Second }));
    var foreJson = JsonSerializer.Serialize(foreLabels.Zip(foreTemps).Select(x => new { x = x.First, y = x.Second }));
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Weather</h1>
    <div class="d-flex gap-2">
        <form asp-action="FetchNow" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-primary">Fetch Snapshot Now</button>
        </form>
        <form asp-action="FetchForecastNow" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-primary">Fetch Forecast Now</button>
        </form>
    </div>
</div>

<h2 class="mt-2 mb-3">Temperature Overview</h2>
<div style="position:relative; height:350px;">
    <canvas id="tempChart"></canvas>
</div>

<h2 class="mt-5 mb-2">15-Minute Forecast</h2>
@if (!Model.Forecast.Any())
{
    <div class="alert alert-warning">No forecast stored yet — the background service fetches it automatically, or click "Fetch Forecast Now".</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-bordered table-hover">
            <thead class="table-warning">
                <tr>
                    <th>Time</th>
                    <th>Temp (°C)</th>
                    <th>Wind (km/h)</th>
                    <th>Direction</th>
                    <th>Precip %</th>
                    <th>Cloud %</th>
                    <th>Condition</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var slot in Model.Forecast)
                {
                    <tr>
                        <td>@slot.ValidTime.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td><strong>@slot.Temperature</strong></td>
                        <td>@slot.WindSpeed</td>
                        <td>@slot.WindDirection</td>
                        <td>@slot.PrecipChance</td>
                        <td>@slot.CloudCover</td>
                        <td>@slot.WxPhrase</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<h2 class="mt-5 mb-2">Historical Data</h2>
@if (!Model.Historical.Any())
{
    <div class="alert alert-info">No weather snapshots yet. Click "Fetch Snapshot Now" to get started.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Time</th>
                <th>Location</th>
                <th>Temp (°C)</th>
                <th>Wind (km/h)</th>
                <th>Direction</th>
                <th>Sky</th>
                <th>Condition</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Historical)
            {
                <tr>
                    <td>@item.TimeStamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@item.Location</td>
                    <td><strong>@item.Temperature °C</strong></td>
                    <td>@item.WindSpeed km/h</td>
                    <td>@item.WindDirection</td>
                    <td>@item.SkyCondition</td>
                    <td>@item.WxPhrase</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const historical = @Html.Raw(histJson);
        const forecast   = @Html.Raw(foreJson);

        new Chart(document.getElementById('tempChart'), {
            type: 'line',
            data: {
                datasets: [
                    {
                        label: 'Historical (°C)',
                        data: historical,
                        borderColor: '#0d6efd',
                        backgroundColor: 'rgba(13,110,253,0.08)',
                        tension: 0.3,
                        pointRadius: 3,
                        fill: false
                    },
                    {
                        label: 'Forecast (°C)',
                        data: forecast,
                        borderColor: '#fd7e14',
                        backgroundColor: 'rgba(253,126,20,0.08)',
                        borderDash: [6, 3],
                        tension: 0.3,
                        pointRadius: 3,
                        fill: false
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                parsing: { xAxisKey: 'x', yAxisKey: 'y' },
                scales: {
                    x: {
                        type: 'category',
                        title: { display: true, text: 'Time' },
                        ticks: { maxTicksLimit: 20, maxRotation: 45 }
                    },
                    y: {
                        title: { display: true, text: 'Temperature (°C)' }
                    }
                },
                plugins: {
                    legend: { position: 'top' },
                    tooltip: { mode: 'index', intersect: false }
                }
            }
        });
    </script>
}
