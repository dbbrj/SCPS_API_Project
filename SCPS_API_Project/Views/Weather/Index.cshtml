@model IEnumerable<SCPS_API_Project.Models.WeatherModel>

@{
    ViewData["Title"] = "Weather History";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Weather History</h1>
    <form asp-action="FetchNow" method="post">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-primary">Fetch New Snapshot</button>
    </form>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No weather snapshots yet. Click "Fetch New Snapshot" to get started.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>@Html.DisplayNameFor(m => m.TimeStamp)</th>
                <th>@Html.DisplayNameFor(m => m.Location)</th>
                <th>@Html.DisplayNameFor(m => m.Temperature)</th>
                <th>@Html.DisplayNameFor(m => m.WindSpeed)</th>
                <th>@Html.DisplayNameFor(m => m.WindDirection)</th>
                <th>@Html.DisplayNameFor(m => m.SkyCondition)</th>
                <th>@Html.DisplayNameFor(m => m.WxPhrase)</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.TimeStamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@item.Location</td>
                    <td><strong>@item.Temperature °C</strong></td>
                    <td>@item.WindSpeed km/h</td>
                    <td>@item.WindDirection</td>
                    <td>@item.SkyCondition</td>
                    <td>@item.WxPhrase</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
