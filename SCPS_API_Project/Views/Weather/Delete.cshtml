@model SCPS_API_Project.Models.WeatherModel

@{
    ViewData["Title"] = "Delete Snapshot";
}

<h1>Delete Snapshot</h1>

<div class="alert alert-warning">Are you sure you want to delete this snapshot?</div>

<div class="card" style="max-width: 400px;">
    <ul class="list-group list-group-flush">
        <li class="list-group-item"><strong>@Model.Location</strong> &mdash; @Model.TimeStamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</li>
        <li class="list-group-item">Temperature: @Model.Temperature °C</li>
        <li class="list-group-item">Wind: @Model.WindSpeed km/h @Model.WindDirection</li>
        <li class="list-group-item">Sky: @Model.SkyCondition — @Model.WxPhrase</li>
    </ul>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Delete" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
