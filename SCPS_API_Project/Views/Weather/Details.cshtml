@model SCPS_API_Project.Models.WeatherModel

@{
    ViewData["Title"] = "Snapshot Details";
}

<h1>Snapshot Details</h1>

<div class="card" style="max-width: 500px;">
    <div class="card-header">
        <strong>@Model.Location</strong> &mdash; @Model.TimeStamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
    </div>
    <ul class="list-group list-group-flush">
        <li class="list-group-item d-flex justify-content-between">
            <span>@Html.DisplayNameFor(m => m.Temperature)</span>
            <strong>@Model.Temperature °C</strong>
        </li>
        <li class="list-group-item d-flex justify-content-between">
            <span>@Html.DisplayNameFor(m => m.WindSpeed)</span>
            <span>@Model.WindSpeed km/h</span>
        </li>
        <li class="list-group-item d-flex justify-content-between">
            <span>@Html.DisplayNameFor(m => m.WindDirection)</span>
            <span>@Model.WindDirection</span>
        </li>
        <li class="list-group-item d-flex justify-content-between">
            <span>@Html.DisplayNameFor(m => m.SkyCondition)</span>
            <span>@Model.SkyCondition</span>
        </li>
        <li class="list-group-item d-flex justify-content-between">
            <span>@Html.DisplayNameFor(m => m.WxPhrase)</span>
            <span>@Model.WxPhrase</span>
        </li>
    </ul>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Back to History</a>
</div>
